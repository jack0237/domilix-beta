    "start": "cross-env NODE_ENV=production node server/index.cjs",
    "preview": "npm run build && npm run start"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "nodemailer": "^9.0.1",
    "preact": "^10.23.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.2"
  }
}
