{
  "name": "domilix-beta",
  "version": "1.0.0",
  "private": true,
  "description": "Page d'inscription au programme bêta de Domilix",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,API\" -c \"cyan,yellow\" \"vite\" \"node server/index.cjs\"",
