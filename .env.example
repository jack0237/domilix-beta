# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3001
ADMIN_KEY=change-this-secret-key

# ── SMTP — Configuration e-mail ───────────────────────────────────────────────
# Exemples de fournisseurs :
#
# Gmail (nécessite un "Mot de passe d'application" dans les paramètres Google)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=votre@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   ← mot de passe d'application, pas votre mdp Gmail
#
# Brevo (ex-Sendinblue) — recommandé, plan gratuit 300 mails/jour
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=votre@email.com
#   SMTP_PASS=votre-cle-api-brevo
#
# SendGrid
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=votre-cle-api-sendgrid

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Domilix <noreply@domilix.com>
